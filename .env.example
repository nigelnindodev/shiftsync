# Server Configuration

# Enable testing endpoints
# Set to true in test environment to acees pre-created employee profiles
ENABLE_TESTING_ENDPOINTS=true

# Encryption Keys (Required JSON)
# Example format: {"current": "v1", "keys": {"v1": "base64encodedkey"}}
# You can generate a random base64 string using: openssl rand -base64 32
ENCRYPTION_KEYS='{"current": "v1", "keys": {"v1": "change_me_to_base64_string"}}'
